// LaundryKu — Prisma Schema
// PostgreSQL | 22 Tables | Prisma 7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum PlanType {
  regular
  pro
}

enum DurationMonths {
  ONE    @map("1")
  THREE  @map("3")
  SIX    @map("6")
  TWELVE @map("12")

  @@map("duration_months")
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  grace_period
}

enum PaymentStatus {
  pending
  success
  failed
  expired
  refunded
}

enum StaffRole {
  kasir
  operator
}

enum UserType {
  owner
  staff
}

enum ServiceUnit {
  kg
  pcs
  meter
}

enum OrderStatus {
  pending
  processing
  ready
  completed
  cancelled
}

enum OrderPaymentStatus {
  unpaid
  partial
  paid
}

enum PaymentMethod {
  cash
  transfer
  qris
}

enum InventoryLogType {
  in
  out
  adjustment
}

enum NotificationType {
  order_new
  order_deadline
  order_overdue
  stock_low
  expense_anomaly
  subscription_expiring
  subscription_expired
}

enum PeriodType {
  daily
  weekly
  monthly
}

// ============================================================
// 1. USERS (Owner)
// ============================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(255)
  phone         String    @db.VarChar(20)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  avatarUrl     String?   @map("avatar_url") @db.VarChar(500)
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  verifyEmailToken     String?   @map("verify_email_token") @db.VarChar(64)
  verifyEmailExpires   DateTime? @map("verify_email_expires") @db.Timestamptz
  resetPasswordToken   String?   @map("reset_password_token") @db.VarChar(64)
  resetPasswordExpires DateTime? @map("reset_password_expires") @db.Timestamptz

  outlets  Outlet[]
  payments Payment[]

  @@index([email])
  @@map("users")
}

// ============================================================
// 2. OUTLETS
// ============================================================

model Outlet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(150)
  address   String?  @db.Text
  phone     String?  @db.VarChar(20)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions     Subscription[]
  staff             Staff[]
  services          Service[]
  customers         Customer[]
  orders            Order[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  inventoryItems    InventoryItem[]
  attendances       Attendance[]
  notifications     Notification[]
  profitAnalyses    ProfitAnalysis[]
  costAllocations   CostAllocation[]
  healthScores      HealthScore[]
  orderSequence     OrderSequence?

  @@index([userId])
  @@map("outlets")
}

// ============================================================
// 3. SUBSCRIPTIONS
// ============================================================

model Subscription {
  id             String             @id @default(uuid()) @db.Uuid
  outletId       String             @map("outlet_id") @db.Uuid
  planType       PlanType           @map("plan_type")
  durationMonths Int                @map("duration_months")
  pricePaid      Decimal            @map("price_paid") @db.Decimal(12, 2)
  discountAmount Decimal            @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountReason String?            @map("discount_reason") @db.VarChar(100)
  startDate      DateTime           @map("start_date") @db.Date
  endDate        DateTime           @map("end_date") @db.Date
  status         SubscriptionStatus @default(active)
  autoRenew      Boolean            @default(false) @map("auto_renew")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  outlet   Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([outletId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// ============================================================
// 4. PAYMENTS
// ============================================================

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  subscriptionId String?       @map("subscription_id") @db.Uuid
  paymentFor     String        @default("subscription") @map("payment_for") @db.VarChar(30)
  amount         Decimal       @db.Decimal(12, 2)
  provider       String?       @db.VarChar(30)
  providerRefId  String?       @map("provider_ref_id") @db.VarChar(255)
  paymentMethod  String?       @map("payment_method") @db.VarChar(50)
  status         PaymentStatus @default(pending)
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz
  expiredAt      DateTime?     @map("expired_at") @db.Timestamptz
  rawResponse    Json?         @map("raw_response")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payments")
}

// ============================================================
// 5. STAFF
// ============================================================

model Staff {
  id          String    @id @default(uuid()) @db.Uuid
  outletId    String    @map("outlet_id") @db.Uuid
  name        String    @db.VarChar(100)
  phone       String?   @db.VarChar(20)
  username    String    @db.VarChar(50)
  pinHash     String    @map("pin_hash") @db.VarChar(255)
  role        StaffRole @default(kasir)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  outlet      Outlet       @relation(fields: [outletId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([outletId, username])
  @@index([outletId])
  @@map("staff")
}

// ============================================================
// 6. SESSIONS
// ============================================================

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userType     UserType @map("user_type")
  userRefId    String   @map("user_ref_id") @db.Uuid // polymorphic: users.id or staff.id
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  deviceInfo   String?  @map("device_info") @db.VarChar(300)
  ipAddress    String?  @map("ip_address") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at") @db.Timestamptz
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userType, userRefId])
  @@index([refreshToken])
  @@map("sessions")
}

// ============================================================
// 7. SERVICES
// ============================================================

model Service {
  id             String      @id @default(uuid()) @db.Uuid
  outletId       String      @map("outlet_id") @db.Uuid
  name           String      @db.VarChar(100)
  price          Decimal     @db.Decimal(12, 2)
  unit           ServiceUnit @default(kg)
  estimatedHours Int         @default(24) @map("estimated_hours")
  sortOrder      Int         @default(0) @map("sort_order")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  outlet          Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  profitAnalyses  ProfitAnalysis[]
  costAllocations CostAllocation[]

  @@index([outletId])
  @@map("services")
}

// ============================================================
// 8. CUSTOMERS
// ============================================================

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  outletId  String   @map("outlet_id") @db.Uuid
  name      String   @db.VarChar(100)
  phone     String   @db.VarChar(20)
  address   String?  @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  outlet Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([outletId, phone])
  @@index([outletId])
  @@index([outletId, phone])
  @@index([outletId, name])
  @@map("customers")
}

// ============================================================
// 9. ORDERS
// ============================================================

model Order {
  id              String             @id @default(uuid()) @db.Uuid
  outletId        String             @map("outlet_id") @db.Uuid
  customerId      String?            @map("customer_id") @db.Uuid
  orderNumber     String             @map("order_number") @db.VarChar(20)
  status          OrderStatus        @default(pending)
  paymentStatus   OrderPaymentStatus @default(unpaid) @map("payment_status")
  paymentMethod   PaymentMethod?     @map("payment_method")
  subtotal        Decimal            @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal            @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount     Decimal            @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal            @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes           String?            @db.Text
  estimatedDoneAt DateTime?          @map("estimated_done_at") @db.Timestamptz
  completedAt     DateTime?          @map("completed_at") @db.Timestamptz
  cancelledAt     DateTime?          @map("cancelled_at") @db.Timestamptz
  cancelReason    String?            @map("cancel_reason") @db.VarChar(255)
  createdBy       String?            @map("created_by") @db.Uuid // polymorphic
  createdByType   String?            @map("created_by_type") @db.VarChar(10)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  outlet        Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  customer      Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
  statusHistory OrderStatusHistory[]
  inventoryLogs InventoryLog[]

  @@index([outletId])
  @@index([customerId])
  @@index([outletId, status])
  @@index([outletId, paymentStatus])
  @@index([outletId, orderNumber])
  @@index([outletId, createdAt(sort: Desc)])
  @@map("orders")
}

// ============================================================
// 10. ORDER ITEMS
// ============================================================

model OrderItem {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  serviceId    String?  @map("service_id") @db.Uuid
  serviceName  String   @map("service_name") @db.VarChar(100)
  pricePerUnit Decimal  @map("price_per_unit") @db.Decimal(12, 2)
  unit         String   @db.VarChar(10)
  quantity     Decimal  @db.Decimal(10, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([serviceId])
  @@map("order_items")
}

// ============================================================
// 11. ORDER STATUS HISTORY
// ============================================================

model OrderStatusHistory {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  fromStatus    String?  @map("from_status") @db.VarChar(20)
  toStatus      String   @map("to_status") @db.VarChar(20)
  changedBy     String?  @map("changed_by") @db.Uuid // polymorphic
  changedByType String?  @map("changed_by_type") @db.VarChar(10)
  notes         String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================
// 12. EXPENSE CATEGORIES
// ============================================================

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  outletId  String   @map("outlet_id") @db.Uuid
  name      String   @db.VarChar(50)
  slug      String   @db.VarChar(50)
  isDefault Boolean  @default(false) @map("is_default")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  outlet         Outlet                @relation(fields: [outletId], references: [id], onDelete: Cascade)
  subcategories  ExpenseSubcategory[]
  expenses       Expense[]

  @@index([outletId])
  @@map("expense_categories")
}

model ExpenseSubcategory {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  name       String   @db.VarChar(50)
  slug       String   @db.VarChar(50)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@map("expense_subcategories")
}

// ============================================================
// 13. EXPENSES
// ============================================================

model Expense {
  id             String    @id @default(uuid()) @db.Uuid
  outletId       String    @map("outlet_id") @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  subcategoryId  String?   @map("subcategory_id") @db.Uuid
  amount         Decimal   @db.Decimal(12, 2)
  expenseDate    DateTime  @map("expense_date") @db.Date
  notes          String?   @db.Text
  isRecurring    Boolean   @default(false) @map("is_recurring")
  recurringDay   Int?      @map("recurring_day")
  createdBy      String?   @map("created_by") @db.Uuid // polymorphic
  createdByType  String?   @map("created_by_type") @db.VarChar(10)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  outlet      Outlet              @relation(fields: [outletId], references: [id], onDelete: Cascade)
  category    ExpenseCategory     @relation(fields: [categoryId], references: [id])
  subcategory ExpenseSubcategory? @relation(fields: [subcategoryId], references: [id])

  @@index([outletId])
  @@index([outletId, expenseDate(sort: Desc)])
  @@index([outletId, categoryId])
  @@map("expenses")
}

// ============================================================
// 14. INVENTORY ITEMS (Pro Only)
// ============================================================

model InventoryItem {
  id                String    @id @default(uuid()) @db.Uuid
  outletId          String    @map("outlet_id") @db.Uuid
  name              String    @db.VarChar(100)
  category          String?   @db.VarChar(50)
  unit              String    @db.VarChar(20)
  currentStock      Decimal   @default(0) @map("current_stock") @db.Decimal(10, 2)
  minStockAlert     Decimal   @default(0) @map("min_stock_alert") @db.Decimal(10, 2)
  avgDailyUsage     Decimal   @default(0) @map("avg_daily_usage") @db.Decimal(10, 2)
  estimatedDaysLeft Int       @default(0) @map("estimated_days_left")
  lastRestockedAt   DateTime? @map("last_restocked_at") @db.Timestamptz
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  outlet Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  logs   InventoryLog[]

  @@index([outletId])
  @@map("inventory_items")
}

// ============================================================
// 15. INVENTORY LOGS (Pro Only)
// ============================================================

model InventoryLog {
  id            String           @id @default(uuid()) @db.Uuid
  itemId        String           @map("item_id") @db.Uuid
  type          InventoryLogType
  quantity      Decimal          @db.Decimal(10, 2)
  stockBefore   Decimal          @map("stock_before") @db.Decimal(10, 2)
  stockAfter    Decimal          @map("stock_after") @db.Decimal(10, 2)
  unitCost      Decimal?         @map("unit_cost") @db.Decimal(12, 2)
  totalCost     Decimal?         @map("total_cost") @db.Decimal(12, 2)
  supplier      String?          @db.VarChar(100)
  linkedOrderId String?          @map("linked_order_id") @db.Uuid
  notes         String?          @db.Text
  createdBy     String?          @map("created_by") @db.Uuid // polymorphic
  createdByType String?          @map("created_by_type") @db.VarChar(10)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz

  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  linkedOrder  Order?        @relation(fields: [linkedOrderId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([createdAt(sort: Desc)])
  @@index([itemId, type])
  @@map("inventory_logs")
}

// ============================================================
// 16. ATTENDANCES
// ============================================================

model Attendance {
  id          String    @id @default(uuid()) @db.Uuid
  outletId    String    @map("outlet_id") @db.Uuid
  staffId     String    @map("staff_id") @db.Uuid
  clockIn     DateTime  @map("clock_in") @db.Timestamptz
  clockOut    DateTime? @map("clock_out") @db.Timestamptz
  durationMin Int?      @map("duration_min")
  notes       String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([outletId])
  @@index([staffId])
  @@index([outletId, clockIn(sort: Desc)])
  @@map("attendances")
}

// ============================================================
// 17. NOTIFICATIONS
// ============================================================

model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  outletId      String           @map("outlet_id") @db.Uuid
  recipientType String           @map("recipient_type") @db.VarChar(10) // 'owner' | 'staff'
  recipientId   String           @map("recipient_id") @db.Uuid // polymorphic
  type          NotificationType
  title         String           @db.VarChar(150)
  message       String           @db.Text
  data          Json?
  isRead        Boolean          @default(false) @map("is_read")
  readAt        DateTime?        @map("read_at") @db.Timestamptz
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([recipientType, recipientId])
  @@index([outletId])
  @@map("notifications")
}

// ============================================================
// 18. PROFIT ANALYSIS CACHE (Pro Only)
// ============================================================

model ProfitAnalysis {
  id            String     @id @default(uuid()) @db.Uuid
  outletId      String     @map("outlet_id") @db.Uuid
  serviceId     String?    @map("service_id") @db.Uuid
  periodType    PeriodType @map("period_type")
  periodStart   DateTime   @map("period_start") @db.Date
  periodEnd     DateTime   @map("period_end") @db.Date
  totalOrders   Int        @default(0) @map("total_orders")
  totalQuantity Decimal    @default(0) @map("total_quantity") @db.Decimal(10, 2)
  totalRevenue  Decimal    @default(0) @map("total_revenue") @db.Decimal(14, 2)
  allocatedCost Decimal    @default(0) @map("allocated_cost") @db.Decimal(14, 2)
  profit        Decimal    @default(0) @db.Decimal(14, 2)
  marginPct     Decimal    @default(0) @map("margin_pct") @db.Decimal(5, 2)
  calculatedAt  DateTime   @default(now()) @map("calculated_at") @db.Timestamptz

  outlet  Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([outletId, serviceId, periodType, periodStart])
  @@index([outletId])
  @@index([outletId, periodType, periodStart])
  @@map("profit_analysis")
}

// ============================================================
// 19. COST ALLOCATION SETTINGS (Pro Only)
// ============================================================

model CostAllocation {
  id            String   @id @default(uuid()) @db.Uuid
  outletId      String   @map("outlet_id") @db.Uuid
  serviceId     String   @map("service_id") @db.Uuid
  allocationPct Decimal  @default(0) @map("allocation_pct") @db.Decimal(5, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([outletId, serviceId])
  @@map("cost_allocations")
}

// ============================================================
// 20. HEALTH SCORES (Pro Only)
// ============================================================

model HealthScore {
  id                  String   @id @default(uuid()) @db.Uuid
  outletId            String   @map("outlet_id") @db.Uuid
  scoreDate           DateTime @map("score_date") @db.Date
  overallScore        Int      @map("overall_score")
  profitMarginScore   Int?     @map("profit_margin_score")
  revenueTrendScore   Int?     @map("revenue_trend_score")
  expenseRatioScore   Int?     @map("expense_ratio_score")
  inventoryScore      Int?     @map("inventory_score")
  completionRateScore Int?     @map("completion_rate_score")
  insights            Json?
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, scoreDate])
  @@index([outletId, scoreDate(sort: Desc)])
  @@map("health_scores")
}

// ============================================================
// 21. ORDER SEQUENCES (per Outlet)
// ============================================================

model OrderSequence {
  outletId   String @id @map("outlet_id") @db.Uuid
  lastNumber Int    @default(0) @map("last_number")

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@map("order_sequences")
}
